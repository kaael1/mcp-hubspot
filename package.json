{
  "name": "mcp-hubspot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-mediated HubSpot MCP server and Chromium extension for using HubSpot without admin API access.",
  "bin": {
    "mcp-hubspot": "dist/server/index.js"
  },
  "scripts": {
    "start": "tsx server/index.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
