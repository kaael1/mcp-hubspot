{
  "manifest_version": 3,
  "name": "HubSpot Browser MCP Bridge",
  "description": "Mediates approved HubSpot browser actions for the local MCP bridge without exporting browser tokens.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "scripting", "sidePanel", "alarms", "webNavigation"],
  "host_permissions": ["*://*.hubspot.com/*", "http://127.0.0.1:17437/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hubspot.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HubSpot Browser MCP"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
